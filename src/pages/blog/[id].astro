---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPost, getAllBlogIds, formatDate, dummyPosts } from '../../lib/microcms';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const ids = await getAllBlogIds();
  return ids.map(id => ({ params: { id } }));
};

const { id } = Astro.params;
const post = await getBlogPost(id!);

if (!post) return Astro.redirect('/blog');

// Related posts (same category, excluding current)
const related = dummyPosts
  .filter(p => p.category === post.category && p.id !== post.id)
  .slice(0, 2);
---

<BaseLayout
  title={`${post.title} | 山田太郎 Blog`}
  description={post.body.replace(/<[^>]+>/g, '').slice(0, 120)}
>
  <article class="blog-article">
    <!-- Hero -->
    <div class="article-hero">
      {post.thumbnail && (
        <div class="article-hero-img">
          <img
            src={post.thumbnail.url}
            alt={post.title}
            width="1200"
            height="675"
            loading="eager"
          />
        </div>
      )}
      <div class="article-hero-overlay">
        <div class="container">
          <span class="tag">{post.category}</span>
          <h1 class="article-title">{post.title}</h1>
          <div class="article-meta">
            <time>{formatDate(post.publishedAt)}</time>
          </div>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="container article-body-wrap">
      <div class="article-nav-back">
        <a href="/blog" class="back-link">← ブログ一覧へ</a>
      </div>
      <div class="prose article-body" set:html={post.body} />
    </div>

    <!-- Related Posts -->
    {related.length > 0 && (
      <section class="section related-section">
        <div class="container">
          <h2 class="related-title">関連記事</h2>
          <div class="related-grid">
            {related.map(p => (
              <a href={`/blog/${p.id}`} class="blog-card card">
                <div class="blog-card-img">
                  <img src={p.thumbnail?.url} alt={p.title} loading="lazy" width="800" height="450" />
                  <span class="blog-card-cat tag">{p.category}</span>
                </div>
                <div class="blog-card-body">
                  <time class="blog-date">{formatDate(p.publishedAt)}</time>
                  <h3 class="blog-card-title">{p.title}</h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  /* Hero */
  .article-hero { position: relative; }
  .article-hero-img {
    aspect-ratio: 21/9; overflow: hidden;
  }
  .article-hero-img img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .article-hero-overlay {
    background: var(--color-surface-alt);
    padding: 7rem 0 3rem;
  }
  @media (min-width: 768px) {
    .article-hero-img { aspect-ratio: 16/5; }
    .article-hero-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(255,255,255,0.97) 0%, rgba(255,255,255,0.8) 60%, transparent 100%);
      padding: 4rem 0 2rem;
    }
  }
  .article-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin: 1rem 0 0.75rem;
    line-height: 1.25;
    max-width: 20em;
  }
  .article-meta { font-size: 0.875rem; color: var(--color-text-muted); }

  /* Body */
  .article-body-wrap { padding-top: 3rem; padding-bottom: 5rem; }
  .article-nav-back { margin-bottom: 2rem; }
  .back-link {
    font-size: 0.875rem; color: var(--color-text-muted);
    font-family: 'Outfit', sans-serif; font-weight: 600;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-text); }
  .article-body { margin: 0 auto; }

  /* Related */
  .related-section { background: var(--color-surface-alt); }
  .related-title {
    font-size: 1.5rem; margin-bottom: 2rem;
    font-family: 'Outfit', sans-serif;
  }
  .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .blog-card { display: block; }
  .blog-card-img { position: relative; overflow: hidden; aspect-ratio: 16/9; }
  .blog-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .blog-card:hover .blog-card-img img { transform: scale(1.04); }
  .blog-card-cat { position: absolute; bottom: 0.75rem; left: 0.75rem; }
  .blog-card-body { padding: 1.25rem; }
  .blog-date { display: block; font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 0.5rem; }
  .blog-card-title { font-size: 1rem; margin: 0; font-family: 'Noto Sans JP', sans-serif; font-weight: 500; line-height: 1.65; }

  @media (max-width: 640px) { .related-grid { grid-template-columns: 1fr; } }
</style>
